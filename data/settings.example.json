{
  "schema_version": 3,
  "general": {
    "launch_on_startup": false,
    "open_avatar_window": true,
    "avatar_always_on_top": false,
    "remember_window_positions": true
  },
  "llm": {
    "backend": "lm_studio",
    "base_url": "http://localhost:1234/v1",
    "api_key": "None",
    "model": "gemma4-12b-qat-uncensored-hauhaucs-balanced",
    "temperature": 0.75,
    "top_p": 0.9,
    "max_tokens": 1024,
    "max_short_term_messages": 20,
    "stop_sequences": [
      "\nUser:",
      "\nUSER:",
      "\nHuman:",
      "\nAssistant:",
      "<|im_end|>",
      "<|endoftext|>"
    ],
    "retry_empty_response": true,
    "empty_response_retries": 1,
    "retry_token_multiplier": 2.0,
    "max_retry_tokens": 2048,
    "reasoning_mode": "off"
  },
  "personality": {
    "preset": "gamer",
    "prompt": ""
  },
  "stt": {
    "model": "base",
    "device": "cuda",
    "compute_type": "float16",
    "language": null,
    "beam_size": 5
  },
  "audio": {
    "recording_file": "input.wav",
    "input_device": null,
    "output_device": null,
    "sample_rate": 16000,
    "channels": 1,
    "frame_ms": 30,
    "pre_roll_seconds": 0.35,
    "end_silence_seconds": 2.0,
    "min_record_seconds": 0.45,
    "max_record_seconds": 45.0,
    "calibration_seconds": 0.6,
    "start_threshold_multiplier": 6.0,
    "end_threshold_multiplier": 1.8,
    "min_start_threshold": 0.02,
    "min_end_threshold": 0.006
  },
  "tts": {
    "voice_index": 1,
    "rate": 175,
    "volume": 1.0
  },
  "avatar": {
    "enabled": true,
    "backend": "vmc",
    "vmc_ip": "127.0.0.1",
    "vmc_port": 39539,
    "face_blend_fps": 120,
    "mouth_fps": 28,
    "mouth_start_delay_seconds": 1.15,
    "mouth_end_delay_seconds": 0.05,
    "mouth_scale": 0.95,
    "mouth_random_amount": 0.08,
    "mouth_attack_speed": 0.6,
    "mouth_release_speed": 0.42,
    "reset_other_vowels_each_frame": true,
    "expressions_enabled": true,
    "idle_face_enabled": true,
    "idle_blinks_enabled": false,
    "idle_gaze_enabled": false,
    "idle_face_fps": 20,
    "idle_expression_strength": 0.3,
    "speaking_expression_strength": 0.72,
    "expression_fade_speed": 0.08,
    "auto_start_idle": true,
    "standing_pose_replay_enabled": true,
    "pose_fps": 18,
    "body_idle_strength": 1.0,
    "body_root_bob_meters": 0.012,
    "body_sway_meters": 0.01,
    "body_breath_degrees": 2.2,
    "body_head_yaw_degrees": 2.4,
    "body_arm_sway_degrees": 1.8,
    "disable_idle_during_expressions": true,
    "idle_strength_during_expressions": 0.2,
    "random_idle_expressions_enabled": false,
    "body_expressions_enabled": true,
    "body_expression_strength": 1.0,
    "body_pose_strength": 1.0,
    "body_expression_fade_speed": 0.055,
    "body_speaking_motion_boost": 0.28,
    "body_talk_pulse_degrees": 1.35,
    "body_talk_hand_meters": 0.01,
    "arm_gesture_strength": 1.0,
    "arm_tracker_strength": 0.0,
    "arm_bone_rotation_strength": 1.0,
    "arm_speaking_sway_meters": 0.018,
    "arm_speaking_lift_meters": 0.014,
    "send_tracker_positions": false,
    "skip_eye_bones": true
  },
  "memory": {
    "file": "data/memories.json",
    "max_turns": 300,
    "max_facts": 200,
    "max_context_chars": 2500,
    "recent_turns": 6,
    "relevant_limit": 6
  }
}
